# Google OAuth
VITE_GOOGLE_CLIENT_ID=

# AI / Gemini
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL_ANALYSIS=gemini-2.0-flash-exp
VITE_GEMINI_MODEL_GENERATION=imagen-3.0-generate-001

# API Gateway
# 本地開發: http://localhost:7071/api
# 生產環境: /api  (SWA 代理，不需完整 URL)
VITE_API_BASE_URL=http://localhost:7071/api

# Local auth bypass (本地開發才設 true，生產環境必須為 false)
VITE_AUTH_BYPASS=false

# LINE Integration (Track B: LIFF Share)
# Create a LIFF App in LINE Developers Console -> Messaging API -> LIFF -> Add
VITE_LIFF_ID=
